# cloudformation_write_safety.rules
# Technology: cloudformation | Capability: write

rule cloudformation-block-unsafe-patterns {
  enabled true
  priority 90
  severity error
  DENY write
  IF path GLOB "**/*" AND content CONTAINS "UNSAFE_cloudformation_PATTERN"
  MESSAGE "Blocked an unsafe pattern in cloudformation. Use the recommended best practices for 2025/2026."
}

rule cloudformation-force-updated-api {
  enabled true
  priority 80
  severity warning
  ASK write
  IF path GLOB "**/*" AND content CONTAINS "OLD_cloudformation_API"
  MESSAGE "You are using an outdated API for cloudformation. Please upgrade to the newer API."
}
